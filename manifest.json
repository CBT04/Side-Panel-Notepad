{
"manifest_version": 3,
"name": "SidePanel Notepad",
"version": "2.1",
"description": "A simple note-taking extension that uses the SidePanel.",
"permissions":
[   
    "storage",
    "sidePanel",
    "clipboardWrite",
    "clipboardRead",
    "unlimitedStorage"
],
"icons":
{
    "128": "images/icon128.png",
    "48": "images/icon48.png",
    "16": "images/icon16.png"
},
"side_panel": 
{
      "default_path": "sidePanel.html"
},
"background":
{
    "service_worker": "background.js"
}
}